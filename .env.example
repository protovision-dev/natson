# Copy to .env and fill in real values. .env is gitignored.

# --- Postgres (main datastore) -----------------------------------------
POSTGRES_DB=natson
POSTGRES_USER=natson
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# --- Metabase ----------------------------------------------------------
# Metabase stores its internal state in a separate DB inside the same
# Postgres instance. The `metabase` database is created by db/init/.
METABASE_DB=metabase
METABASE_DB_USER=metabase
METABASE_DB_PASSWORD=change_me
METABASE_PORT=3010

# One-time admin identity used by metabase/provision.py to bootstrap
# the Metabase UI (admin account + Postgres connection + dashboards).
METABASE_ADMIN_EMAIL=admin@natson.local
METABASE_ADMIN_PASSWORD=change_me_long_enough
METABASE_ADMIN_FIRST_NAME=Natson
METABASE_ADMIN_LAST_NAME=Admin

# --- Lighthouse login --------------------------------------------------
LH_USER=
LH_PASS=

# --- Residential proxy (used by browser-api for Booking.com paths) -----
# Left blank here — browser-api/.env is the canonical location; this is
# only read by the root compose if you consolidate env files.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# --- Firecrawl (Booking.com cross-check) -------------------------------
FIRECRAWL_KEY=
