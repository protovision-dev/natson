# Copy to .env and fill in real values. .env is gitignored.

# --- Postgres (main datastore) -----------------------------------------
POSTGRES_DB=natson
POSTGRES_USER=natson
POSTGRES_PASSWORD=change_me
POSTGRES_PORT=5432

# --- Lighthouse login --------------------------------------------------
LH_USER=
LH_PASS=

# --- Residential proxy (used by browser-api for Booking.com paths) -----
# Left blank here — browser-api/.env is the canonical location; this is
# only read by the root compose if you consolidate env files.
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=

# --- Firecrawl (Booking.com cross-check) -------------------------------
FIRECRAWL_KEY=

# --- Web frontend (Next.js + better-auth) ------------------------------
# Read-only DB role consumed by /api/grid, /api/subjects, etc.
NATSON_RO_PASSWORD=change_me
# Owner of the `auth` schema; used by better-auth's pg adapter.
NATSON_AUTH_PASSWORD=change_me
# 32-byte random secret. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=change_me_32_byte_hex
# Public origin the browser hits. Override for staging/prod.
BETTER_AUTH_URL=http://localhost:3020
# Host port mapping for the web service. Default avoids conflict with
# the common :3000 used by open-webui / generic Node services.
WEB_PORT=3020

# --- Jobs API sidecar (Phase C) ----------------------------------------
# Cap concurrent run_job.py subprocesses spawned by jobs-api.
MAX_PARALLEL_JOBS=2

# --- Production domain ------------------------------------------------
# Only read by deploy/docker-compose.prod.yml (Caddy + BETTER_AUTH_URL).
# Dev stack ignores it. Set to your real hostname before running the
# prod overlay.
DOMAIN=natson.protovision.app

# --- Internal service auth (Phase A: prod hardening) ------------------
# Shared secret between web and jobs-api. Even with internal-only
# networking this is defense-in-depth. Generate: openssl rand -hex 32
JOBS_API_INTERNAL_TOKEN=change_me_32_byte_hex

# --- Email (better-auth verification) ---------------------------------
# Resend API key. If unset, verification emails log to stdout — fine
# for dev; required for production (or signups can't complete).
RESEND_API_KEY=
# RFC-5322 From header (e.g. "Natson <noreply@yourdomain.com>")
RESEND_FROM=Natson <noreply@natson.local>
