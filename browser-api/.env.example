# Copy to .env and fill in real values. .env is gitignored.

# Camoufox / server
MAX_CONCURRENCY=4
DEFAULT_UA=Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:140.0) Gecko/20100101 Firefox/140.0
DEFAULT_OS=macos
DEFAULT_LOCALE=en-US

# Residential proxy (Smartproxy). Required — Firefox/Camoufox only honors
# launch-level proxies, so the container won't start cleanly without these
# unless you explicitly remove the PROXY_* env wires in compose.yaml.
PROXY_SERVER=http://proxy.smartproxy.net:3120
PROXY_USERNAME=
PROXY_PASSWORD=
