# Production environment template.
# Copy to .env on the VPS and fill in real values. NEVER commit .env.
#
#   scp .env.production.example ops@vps:/srv/natsonhotels/.env
#   ssh ops@vps 'cd /srv/natsonhotels && $EDITOR .env'
#
# Values marked [secret] must come from a real secret store (1Password,
# Doppler, Vault, GitHub encrypted secrets, etc.) — don't commit and
# don't slack them around.

# --- Public hostname -----------------------------------------------
# Caddy uses this to provision Let's Encrypt certs and to build
# BETTER_AUTH_URL=https://$DOMAIN. DNS must resolve it to the VPS
# BEFORE first boot (or Caddy's ACME challenge fails).
DOMAIN=natson.protovision.app

# --- Postgres ------------------------------------------------------
POSTGRES_DB=natson
POSTGRES_USER=natson
POSTGRES_PASSWORD=replace_me_32_char_random   # [secret]
POSTGRES_PORT=5432  # internal only in prod; not published to host

# --- Web tier (Next.js + better-auth) ------------------------------
NATSON_RO_PASSWORD=replace_me_32_char_random  # [secret]
NATSON_AUTH_PASSWORD=replace_me_32_char_random # [secret]
BETTER_AUTH_SECRET=replace_me_32_byte_hex     # [secret] openssl rand -hex 32

# --- Internal service auth -----------------------------------------
JOBS_API_INTERNAL_TOKEN=replace_me_32_byte_hex  # [secret]
MAX_PARALLEL_JOBS=2

# --- Email (better-auth verification) ------------------------------
RESEND_API_KEY=re_xxxxx                       # [secret]
RESEND_FROM=Natson <noreply@yourdomain.com>

# --- Lighthouse login ----------------------------------------------
LH_USER=ops@yourdomain.com
LH_PASS=replace_me_quoted_if_has_special_chars # [secret]

# --- Residential proxy (Booking.com direct-scrape fallback) --------
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=                                # [secret]

# --- Firecrawl (Booking.com cross-check) ---------------------------
FIRECRAWL_KEY=                                 # [secret]

# --- Web port ------------------------------------------------------
# In the prod overlay, `web:` drops its public `ports:`. Leaving this
# here so NODE_ENV/etc. work if you run the dev compose for debugging.
WEB_PORT=3020
